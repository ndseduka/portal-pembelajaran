---
permalink: "/informatika/"
eleventyExcludeFromCollections: true
---

{% set first = collections.informatika | first %}

<!DOCTYPE html>
<html lang="id">

<head>

    <meta charset="UTF-8">

    {% if first %}
    <meta http-equiv="refresh"
          content="0; url={{ first.url | url }}">
    {% endif %}

    <title>Mengalihkan...</title>

    {% if first %}
    <script>
        window.location.replace("{{ first.url | url }}");
    </script>
    {% endif %}

</head>

<body>

{% if first %}

    <p>
        Mengalihkan ke materi
        <strong>{{ first.data.title }}</strong>...

        <br><br>

        <a href="{{ first.url | url }}">
            Klik di sini jika tidak otomatis.
        </a>

    </p>

{% else %}

    <p>Belum ada materi Informatika.</p>

{% endif %}

</body>

</html>